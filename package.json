{
    "name": "invoice-pdf-generator",
    "version": "1.0.0",
    "description": "Generate Stripe-style invoice PDFs with html2canvas + jsPDF",
    "type": "module",
    "main": "./dist/index.umd.js",
    "module": "./dist/index.es.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.es.js",
            "require": "./dist/index.umd.js",
            "types": "./dist/index.d.ts"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "dev": "vite",
        "build": "tsc && vite build",
        "preview": "vite preview",
        "test": "vitest",
        "type-check": "tsc --noEmit",
        "lint": "eslint src/**/*.ts"
    },
    "keywords": [
        "pdf",
        "invoice",
        "generator",
        "html2canvas",
        "jspdf",
        "stripe",
        "typescript",
        "vite"
    ],
    "author": "Your Name <email@example.com>",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/your-name/invoice-pdf-generator"
    },
    "peerDependencies": {
        "html2canvas": "^1.4.1",
        "jspdf": "^2.5.1"
    },
    "devDependencies": {
        "@types/node": "^20.10.0",
        "@typescript-eslint/eslint-plugin": "^6.13.0",
        "@typescript-eslint/parser": "^6.13.0",
        "eslint": "^8.54.0",
        "html2canvas": "^1.4.1",
        "jspdf": "^2.5.1",
        "typescript": "^5.3.0",
        "vite": "^5.0.0",
        "vite-plugin-dts": "^3.6.0",
        "vitest": "^1.0.0"
    }
}